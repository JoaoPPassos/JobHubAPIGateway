# ─── Gateway ───────────────────────────────────────────
PORT=4000
CORS_ORIGIN=*
PROXY_TIMEOUT=30000

# ─── Authentication ──────────────────────────────────────
# Must match the HASH_TOKEN on the JobHub Service
HASH_TOKEN=your-jwt-secret-here

# ─── Internal API Key ────────────────────────────────────
# Used to protect /jobs and /job-application (worker/internal routes)
INTERNAL_API_KEY=your-internal-api-key-here

# ─── Upstream Services ───────────────────────────────────
JOB_HUB_SERVICE_URL=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────
# THROTTLE_TTL is in milliseconds (default: 60 seconds)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
